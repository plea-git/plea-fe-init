{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "project": ["src/**/*.{ts,tsx}"],
  "ignoreBinaries": ["only-allow"],
  "ignore": [
    "src/api/**",
    "src/app/providers/**",
    "src/shared/ui/**",
    "src/shared/components/**",
    "src/shared/hooks/**",
    "src/shared/lib/**",
    "src/shared/stores/**",
    "src/shared/types/**",
    "src/shared/schemas/**",
    ".storybook/**"
  ],
  "ignoreDependencies": ["@tanstack/react-table", "ky"]
}
